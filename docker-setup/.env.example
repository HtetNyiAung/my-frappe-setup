# --- CENTRAL CONFIGURATION ---
# The internal name for your Docker project stack
STACK_ID="frappe-v16-stack"

# The name and tag for your custom-built image
CUSTOM_IMAGE="frappe-custom-v16:latest"

# The site name used inside Frappe (bench)
SITE_DOMAIN="site1.local"

# Your specific Docker Compose filename
COMPOSE_FILE="pwd-with-apps.yml"

# The exact name of the backend container (verify with 'docker ps')
BACKEND_CONTAINER="docker-setup-backend-1" 

# The version of Frappe/ERPNext to build (e.g., version-16)
FRAPPE_BRANCH="version-16"
# -----------------------------