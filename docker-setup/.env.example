# Project Configuration
STACK_ID=frappe-v16-stack
CUSTOM_IMAGE=my-learning-frappe:v16
FRAPPE_BRANCH=version-16
COMPOSE_FILE=pwd-with-apps.yml
BACKEND_CONTAINER=docker-setup-backend-1
SITE_DOMAIN=frontend

# Production Safety
# Set REQUIRE_PRODUCTION_READY=1 to block setup when unsafe defaults are present.
REQUIRE_PRODUCTION_READY=0
AUTO_BACKUP_BEFORE_SETUP=1
REQUIRE_BACKUP_BEFORE_SETUP=0
LOG_MAX_SIZE=50m
LOG_MAX_FILE=5

# Branding Configuration
PROJECT_NAME="My Learning Frappe"
PRIMARY_COLOR="#0f766e"

# Port Configuration
FRAPPE_PORT=8787
FRAPPE_INTERNAL_PORT=8080
BIND_ADDRESS=0.0.0.0

# Database Configuration
MYSQL_ROOT_PASSWORD=admin
MARIADB_ROOT_PASSWORD=admin
DB_PASSWORD=admin

# Admin Configuration
ADMIN_PASSWORD=admin

# Keycloak Configuration
KC_RUN_MODE=start-dev  # Change to 'start' for production
KC_DB_PASSWORD=keycloak_db_password
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
KC_HOSTNAME=localhost # Change to your domain in production
KC_PORT=8686

# Authentik Configuration
AUTHENTIK_PORT=9000
AUTHENTIK_HTTPS_PORT=9443
AUTHENTIK_DB_PASSWORD=authentik_db_password
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_USER=authentik
# RUN: openssl rand -base64 64 | tr -d '\n' to generate a secret key
AUTHENTIK_SECRET_KEY=yoursecretkey_replacethis
AUTHENTIK_TAG=2024.12.3
AUTHENTIK_BOOTSTRAP_PASSWORD=admin
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
